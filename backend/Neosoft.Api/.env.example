# Copia este archivo como ".env" y ajusta valores (no subas .env al repositorio).
# ASP.NET Core mapea esta variable a ConnectionStrings:DefaultConnection
#
# En appsettings.json el valor de DefaultConnection debe ser SOLO la parte MySQL (Server=...;Port=...),
# nunca incluyas "ConnectionStrings__DefaultConnection=" dentro del JSON.

ConnectionStrings__DefaultConnection=Server=127.0.0.1;Port=3308;Database=neosoft_db;User Id=root;Password=TU_PASSWORD;
